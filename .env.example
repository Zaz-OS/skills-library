# GitHub personal access token (optional but recommended)
# Raises API rate limit from 60 to 5000 req/hr during pipeline enrichment.
# Create one at: https://github.com/settings/tokens (no scopes needed for public repos)
GITHUB_TOKEN=

# Cloudflare D1 (required for pipeline sync)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
D1_DATABASE_ID=

# Astro site API URL (defaults to https://mcp.skills-library.com)
# Set to http://localhost:8787 for local development
PUBLIC_API_URL=
