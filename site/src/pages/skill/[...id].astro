---
export const prerender = false;

import SkillPage from '../../components/SkillPage.astro';

const API_BASE = import.meta.env.PUBLIC_API_URL || "https://mcp.skills-library.com";
const skillId = Astro.params.id;

if (!skillId) {
  return Astro.redirect("/");
}

let skill: any = null;
let skillBody = "";

try {
  const res = await fetch(`${API_BASE}/api/skill/${skillId}`);
  if (res.ok) {
    skill = await res.json();
    skillBody = skill.body || "";
  }
} catch {}

if (!skill) {
  return new Response(null, { status: 404, headers: { Location: "/" } });
}
---
<SkillPage lang="en" skill={skill} skillBody={skillBody} />
