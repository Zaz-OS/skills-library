---
import Base from '../layouts/Base.astro';
import { useTranslations, getLocalizedPath } from '../i18n/utils';
import type { Locale } from '../i18n/translations';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const s = t.whatAreSkills;
---

<Base title={s.pageTitle} lang={lang}>
  <div class="max-w-3xl mx-auto px-5 py-16">

    <!-- Header -->
    <div class="mb-12">
      <div class="flex items-center gap-3 mb-4">
        <span class="px-2.5 py-1 rounded-md bg-accent-sky/10 text-accent-sky text-xs font-mono font-semibold">{s.badge}</span>
      </div>
      <h1 class="font-display text-3xl sm:text-4xl font-bold tracking-tight mb-4">{s.title}</h1>
      <p class="text-ink-muted text-lg leading-relaxed">{s.subtitle}</p>
    </div>

    <!-- The simple version -->
    <section class="mb-12">
      <h2 class="font-display text-xl font-semibold tracking-tight mb-3">{s.simpleTitle}</h2>
      <p class="text-ink-muted leading-relaxed mb-4">{s.simpleP1}</p>
      <p class="text-ink-muted leading-relaxed">{s.simpleP2}</p>
    </section>

    <!-- Analogy -->
    <section class="mb-12 border border-sand-200 rounded-lg bg-white p-6 sm:p-8">
      <div class="text-3xl mb-4">{s.analogyEmoji}</div>
      <h2 class="font-display text-xl font-semibold tracking-tight mb-3">{s.analogyTitle}</h2>
      <p class="text-ink-muted leading-relaxed mb-4">{s.analogyP1}</p>
      <p class="text-ink-muted leading-relaxed">{s.analogyP2}</p>
    </section>

    <!-- What's inside a skill -->
    <section class="mb-12">
      <h2 class="font-display text-xl font-semibold tracking-tight mb-6">{s.insideTitle}</h2>
      <div class="space-y-4">
        {([
          { emoji: '📝', title: s.insideInstructions, desc: s.insideInstructionsDesc },
          { emoji: '⚙️', title: s.insideScripts, desc: s.insideScriptsDesc },
          { emoji: '📚', title: s.insideReferences, desc: s.insideReferencesDesc },
          { emoji: '📎', title: s.insideAssets, desc: s.insideAssetsDesc },
        ] as { emoji: string; title: string; desc: string }[]).map((item) => (
          <div class="flex gap-4 items-start border border-sand-200 rounded-lg bg-white px-5 py-4">
            <span class="text-xl shrink-0 pt-0.5">{item.emoji}</span>
            <div>
              <h3 class="font-display font-semibold text-sm mb-1">{item.title}</h3>
              <p class="text-ink-muted text-sm leading-relaxed">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Why skills make AI more powerful -->
    <section class="mb-12">
      <h2 class="font-display text-xl font-semibold tracking-tight mb-6">{s.whyTitle}</h2>
      <div class="grid gap-4 sm:grid-cols-2">
        {([
          { emoji: '🎯', title: s.whySpecialist, desc: s.whySpecialistDesc },
          { emoji: '🔄', title: s.whyReusable, desc: s.whyReusableDesc },
          { emoji: '🤝', title: s.whyShareable, desc: s.whyShareableDesc },
          { emoji: '🧩', title: s.whyComposable, desc: s.whyComposableDesc },
        ] as { emoji: string; title: string; desc: string }[]).map((item) => (
          <div class="border border-sand-200 rounded-lg bg-white p-5">
            <div class="text-2xl mb-3">{item.emoji}</div>
            <h3 class="font-display font-semibold text-sm mb-1">{item.title}</h3>
            <p class="text-ink-muted text-sm leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Before / After -->
    <section class="mb-12">
      <h2 class="font-display text-xl font-semibold tracking-tight mb-6">{s.beforeAfterTitle}</h2>
      <div class="grid gap-4 sm:grid-cols-2">
        <div class="border border-sand-200 rounded-lg bg-white p-5">
          <div class="flex items-center gap-2 mb-3">
            <span class="text-lg">😐</span>
            <h3 class="font-display font-semibold text-sm text-sand-500">{s.beforeTitle}</h3>
          </div>
          <ul class="space-y-2 text-sm text-ink-muted">
            <li class="flex gap-2"><span class="text-sand-400 shrink-0">-</span>{s.before1}</li>
            <li class="flex gap-2"><span class="text-sand-400 shrink-0">-</span>{s.before2}</li>
            <li class="flex gap-2"><span class="text-sand-400 shrink-0">-</span>{s.before3}</li>
          </ul>
        </div>
        <div class="border border-accent-sage/30 rounded-lg bg-accent-sage/5 p-5">
          <div class="flex items-center gap-2 mb-3">
            <span class="text-lg">🚀</span>
            <h3 class="font-display font-semibold text-sm text-accent-sage">{s.afterTitle}</h3>
          </div>
          <ul class="space-y-2 text-sm text-ink-muted">
            <li class="flex gap-2"><span class="text-accent-sage shrink-0">+</span>{s.after1}</li>
            <li class="flex gap-2"><span class="text-accent-sage shrink-0">+</span>{s.after2}</li>
            <li class="flex gap-2"><span class="text-accent-sage shrink-0">+</span>{s.after3}</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- How to use -->
    <section class="mb-12">
      <h2 class="font-display text-xl font-semibold tracking-tight mb-6">{s.howTitle}</h2>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 sm:gap-0 border border-sand-200 rounded-lg bg-white p-8">
        <div class="text-center flex-1 max-w-[200px]">
          <div class="text-3xl mb-3">🔍</div>
          <h3 class="font-medium text-ink mb-1 font-display">{s.howStep1}</h3>
          <p class="text-sm text-sand-500 leading-relaxed font-body">{s.howStep1Desc}</p>
        </div>
        <div class="text-2xl text-sand-300 hidden sm:block px-4 font-mono">&rarr;</div>
        <div class="text-xl text-sand-300 sm:hidden font-mono">&darr;</div>
        <div class="text-center flex-1 max-w-[200px]">
          <div class="text-3xl mb-3">📋</div>
          <h3 class="font-medium text-ink mb-1 font-display">{s.howStep2}</h3>
          <p class="text-sm text-sand-500 leading-relaxed font-body">{s.howStep2Desc}</p>
        </div>
        <div class="text-2xl text-sand-300 hidden sm:block px-4 font-mono">&rarr;</div>
        <div class="text-xl text-sand-300 sm:hidden font-mono">&darr;</div>
        <div class="text-center flex-1 max-w-[200px]">
          <div class="text-3xl mb-3">✨</div>
          <h3 class="font-medium text-ink mb-1 font-display">{s.howStep3}</h3>
          <p class="text-sm text-sand-500 leading-relaxed font-body">{s.howStep3Desc}</p>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="text-center border border-sand-200 rounded-lg bg-white p-8">
      <h2 class="font-display text-xl font-semibold tracking-tight mb-3">{s.ctaTitle}</h2>
      <p class="text-ink-muted text-sm mb-6 max-w-md mx-auto">{s.ctaDesc}</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a href={getLocalizedPath('/', lang)} class="px-6 py-2.5 rounded-lg bg-accent-coral text-white text-sm font-semibold hover:bg-accent-coral/90 transition-colors">{s.ctaBrowse}</a>
        <a href="https://agentskills.io/specification" target="_blank" rel="noopener" class="px-6 py-2.5 rounded-lg border border-sand-200 text-sm font-semibold text-ink hover:border-sand-300 transition-colors">{s.ctaSpec}</a>
      </div>
    </section>

  </div>
</Base>
