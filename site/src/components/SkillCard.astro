---
interface Props {
  id: string;
  name: string;
  description: string;
  source: string;
  installs: number;
  githubStars: number;
  standalone: boolean;
  contentType: {
    hasScripts: boolean;
    hasReferences: boolean;
    hasAssets: boolean;
  };
  dependencies: { type: string; name: string }[];
}

const { id, name, description, source, installs, githubStars, standalone, contentType, dependencies } = Astro.props;

function formatNumber(n: number): string {
  if (n >= 1000000) return `${(n / 1000000).toFixed(1)}M`;
  if (n >= 1000) return `${(n / 1000).toFixed(1)}k`;
  return String(n);
}
---

<a href={`/skill/${id}`} class="skill-card block bg-gray-900 border border-gray-800 rounded-lg p-4 hover:border-brand-600 hover:bg-gray-900/80 transition-all group">
  <div class="flex items-start justify-between gap-2 mb-2">
    <h3 class="font-medium text-gray-100 group-hover:text-brand-400 transition-colors truncate">{name}</h3>
    {standalone ? (
      <span class="shrink-0 text-xs px-2 py-0.5 rounded-full bg-green-900/50 text-green-400 border border-green-800">standalone</span>
    ) : (
      <span class="shrink-0 text-xs px-2 py-0.5 rounded-full bg-yellow-900/50 text-yellow-400 border border-yellow-800">deps</span>
    )}
  </div>

  {description && (
    <p class="text-sm text-gray-400 mb-3 line-clamp-2">{description}</p>
  )}

  <div class="flex items-center gap-4 text-xs text-gray-500">
    <span class="text-gray-500">{source}</span>
    <span class="flex items-center gap-1" title="Installs">
      <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" /></svg>
      {formatNumber(installs)}
    </span>
    <span class="flex items-center gap-1" title="GitHub Stars">
      <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" /></svg>
      {formatNumber(githubStars)}
    </span>
  </div>

  {dependencies.length > 0 && (
    <div class="mt-2 flex flex-wrap gap-1">
      {dependencies.slice(0, 4).map((dep) => (
        <span class="text-xs px-1.5 py-0.5 rounded bg-gray-800 text-gray-400">{dep.name}</span>
      ))}
      {dependencies.length > 4 && (
        <span class="text-xs px-1.5 py-0.5 rounded bg-gray-800 text-gray-500">+{dependencies.length - 4} more</span>
      )}
    </div>
  )}

  <div class="mt-2 flex gap-1">
    {contentType.hasScripts && <span class="text-xs px-1.5 py-0.5 rounded bg-blue-900/30 text-blue-400">scripts</span>}
    {contentType.hasReferences && <span class="text-xs px-1.5 py-0.5 rounded bg-purple-900/30 text-purple-400">refs</span>}
    {contentType.hasAssets && <span class="text-xs px-1.5 py-0.5 rounded bg-orange-900/30 text-orange-400">assets</span>}
  </div>
</a>
