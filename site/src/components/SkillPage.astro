---
import Base from "../layouts/Base.astro";
import { marked } from "marked";
import { useTranslations, getLocalizedPath } from "../i18n/utils";
import type { Locale } from "../i18n/translations";

interface Props {
  lang: Locale;
  skill: any;
  skillBody: string;
}

marked.setOptions({ breaks: true, gfm: true });

const { lang, skill: rawSkill, skillBody } = Astro.props;
const t = useTranslations(lang);

// Normalize: API returns flat `content` string; legacy JSON has `contentType` object
const skill = {
  ...rawSkill,
  skillId: rawSkill.skillId ?? rawSkill.skill_id ?? "",
  githubStars: rawSkill.githubStars ?? rawSkill.github_stars ?? rawSkill.stars ?? 0,
  repoUrl: rawSkill.repoUrl ?? rawSkill.repo_url ?? `https://github.com/${rawSkill.source}`,
  firstSeen: rawSkill.firstSeen ?? rawSkill.first_seen ?? "",
  contentType: rawSkill.contentType ?? {
    hasInstructions: true,
    hasScripts: (rawSkill.content || "").includes("scripts"),
    hasReferences: (rawSkill.content || "").includes("references"),
    hasAssets: (rawSkill.content || "").includes("assets"),
  },
  dependencies: rawSkill.dependencies ?? [],
};

const renderedHtml = skillBody ? await marked.parse(skillBody) : "";

function formatNumber(n: number): string {
  if (n >= 1000000) return `${(n / 1000000).toFixed(1)}M`;
  if (n >= 1000) return `${(n / 1000).toFixed(1)}k`;
  return String(n);
}

function humanName(name: string): string {
  return name
    .replace(/[-_]/g, " ")
    .replace(/\b\w/g, (c: string) => c.toUpperCase())
    .replace(/\bAi\b/g, "AI")
    .replace(/\bUi\b/g, "UI")
    .replace(/\bUx\b/g, "UX")
    .replace(/\bSeo\b/g, "SEO")
    .replace(/\bApi\b/g, "API")
    .replace(/\bCss\b/g, "CSS")
    .replace(/\bSql\b/g, "SQL");
}

const skillsShUrl = `https://skills.sh/${skill.source}/${skill.skillId}`;
const isCopyReady = skill.standalone && !skill.contentType.hasScripts;
const backHref = getLocalizedPath("/", lang);

const depTypeLabels: Record<string, string> = {
  npm: t.skill.depNpm,
  pip: t.skill.depPip,
  brew: t.skill.depBrew,
  system: t.skill.depSystem,
  service: t.skill.depService,
  other: t.skill.depOther,
};
---

<Base title={`${humanName(skill.name)} — Skills Library`} lang={lang}>
  <div class="max-w-3xl mx-auto px-5 py-10" data-skills-sh-url={skillsShUrl}>
    <!-- Back -->
    <a href={backHref} class="inline-flex items-center gap-1.5 text-sm text-sand-500 hover:text-accent-coral transition-colors mb-8 group font-mono">
      <svg class="w-4 h-4 transition-transform group-hover:-translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" /></svg>
      {t.skill.back}
    </a>

    <!-- Header -->
    <div class="mb-6">
      <div class="flex flex-wrap items-center gap-2 mb-3">
        {isCopyReady ? (
          <span class="flex items-center gap-1.5 px-3 py-1 rounded-md bg-[#f0fdf4] text-[#059669] text-xs font-mono border border-[#bbf7d0]">
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            {t.skill.copyPasteReady}
          </span>
        ) : skill.standalone ? (
          <span class="px-3 py-1 rounded-md bg-[#f0f9ff] text-[#0284c7] text-xs font-mono border border-[#bae6fd]">{t.skill.readyToUse}</span>
        ) : (
          <span class="px-3 py-1 rounded-md bg-[#fffbeb] text-[#d97706] text-xs font-mono border border-[#fde68a]">{t.skill.needsSetup}</span>
        )}
        <a href={skillsShUrl} target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 px-3 py-1 rounded-md bg-sand-100 text-sand-600 text-xs font-mono border border-sand-200 hover:border-sand-300 hover:text-ink transition-colors">
          <svg class="w-3 h-3" viewBox="0 0 16 16" fill="currentColor"><path fill-rule="evenodd" clip-rule="evenodd" d="M8 1L16 15H0L8 1Z"/></svg>
          {formatNumber(skill.installs)} {t.skill.installs}
        </a>
        <a href={skill.repoUrl} target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 px-3 py-1 rounded-md bg-sand-100 text-sand-600 text-xs font-mono border border-sand-200 hover:border-sand-300 hover:text-ink transition-colors">
          <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          {formatNumber(skill.githubStars)} {t.skill.stars}
        </a>
      </div>
      <h1 class="font-display text-3xl font-bold text-ink tracking-tight mb-2">{humanName(skill.name)}</h1>
      <div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-sm text-sand-500 font-mono">
        <span>by <a href={`https://github.com/${skill.source}`} class="hover:text-accent-coral transition-colors" target="_blank" rel="noopener">{skill.source}</a></span>
      </div>
      {skill.description && (
        <p class="text-sand-700 text-lg leading-relaxed mt-4 font-body">{skill.description}</p>
      )}
    </div>

    <!-- Notices -->
    {!skill.standalone && (
      <div class="bg-[#fffbeb] border border-[#fde68a] rounded-lg p-4 mb-5 text-sm text-[#92400e] font-body">
        {t.skill.noticeSetup}
      </div>
    )}
    {skill.contentType.hasScripts && skill.standalone && (
      <div class="bg-[#f0f9ff] border border-[#bae6fd] rounded-lg p-4 mb-5 text-sm text-[#075985] font-body">
        {t.skill.noticeScripts}
      </div>
    )}

    <!-- Skill content -->
    <div class="bg-white border border-sand-200 rounded-lg overflow-hidden mb-6 shadow-sm">
      <div class="flex items-center justify-end px-5 py-2.5 border-b border-sand-100 bg-sand-50/50">
        <button
          id="copy-skill-btn"
          data-copied-text={t.skill.copied}
          class="flex items-center gap-1.5 px-3 py-1.5 text-xs font-mono rounded-md bg-accent-coral text-white hover:bg-accent-coral/90 transition-colors cursor-pointer"
        >
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15.666 3.888A2.25 2.25 0 0013.5 2.25h-3c-1.03 0-1.9.693-2.166 1.638m7.332 0c.055.194.084.4.084.612v0a.75.75 0 01-.75.75H9.75a.75.75 0 01-.75-.75v0c0-.212.03-.418.084-.612m7.332 0c.646.049 1.288.11 1.927.184 1.1.128 1.907 1.077 1.907 2.185V19.5a2.25 2.25 0 01-2.25 2.25H6.75A2.25 2.25 0 014.5 19.5V6.257c0-1.108.806-2.057 1.907-2.185a48.208 48.208 0 011.927-.184" /></svg>
          {t.skill.copy}
        </button>
      </div>
      <div id="skill-content" class="skill-md px-6 py-5 text-sm text-sand-700 leading-relaxed max-h-[32rem] overflow-y-auto" data-raw-content={skillBody}>
        {renderedHtml ? (
          <Fragment set:html={renderedHtml} />
        ) : (
          <div class="text-center py-6 text-sand-400">
            <p class="mb-2">{t.skill.noContent}</p>
            <a href={skillsShUrl} target="_blank" rel="noopener" class="text-accent-coral hover:underline text-sm">{t.skill.viewOnSkillsSh}</a>
          </div>
        )}
      </div>
    </div>

    <!-- Where to add — accordion with brand icons -->
    <div class="mb-10">
      <h2 class="font-display text-lg font-semibold text-ink mb-3">{t.skill.whereToPaste}</h2>
      <div class="border border-sand-200 rounded-lg overflow-hidden bg-white divide-y divide-sand-100 shadow-sm" id="ai-accordion">

        <!-- ChatGPT -->
        <div class="ai-panel">
          <button class="ai-toggle w-full flex items-center gap-3 px-4 py-3 text-left hover:bg-sand-50 transition-colors cursor-pointer font-body">
            <img src="/chatgpt.png" alt="ChatGPT" class="w-5 h-5 shrink-0" />
            <span class="flex-1 text-sm font-medium text-ink">{t.skill.chatgpt}</span>
            <svg class="w-4 h-4 text-sand-400 transition-transform ai-chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" /></svg>
          </button>
          <div class="ai-content hidden px-4 pb-3 font-body">
            <div class="pl-8 text-sm text-sand-600 space-y-1">
              <p><span class="font-medium text-ink">{t.skill.goTo}</span> {t.skill.chatgptPath}</p>
              <p class="text-sand-400 text-xs">{t.skill.chatgptHint}</p>
            </div>
          </div>
        </div>

        <!-- Gemini -->
        <div class="ai-panel">
          <button class="ai-toggle w-full flex items-center gap-3 px-4 py-3 text-left hover:bg-sand-50 transition-colors cursor-pointer font-body">
            <img src="/gemini.png" alt="Gemini" class="w-5 h-5 shrink-0" />
            <span class="flex-1 text-sm font-medium text-ink">{t.skill.gemini}</span>
            <svg class="w-4 h-4 text-sand-400 transition-transform ai-chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" /></svg>
          </button>
          <div class="ai-content hidden px-4 pb-3 font-body">
            <div class="pl-8 text-sm text-sand-600 space-y-1">
              <p><span class="font-medium text-ink">{t.skill.goTo}</span> {t.skill.geminiPath}</p>
              <p class="text-sand-400 text-xs">{t.skill.geminiHint}</p>
            </div>
          </div>
        </div>

        <!-- Claude web -->
        <div class="ai-panel">
          <button class="ai-toggle w-full flex items-center gap-3 px-4 py-3 text-left hover:bg-sand-50 transition-colors cursor-pointer font-body">
            <img src="/claude.png" alt="Claude" class="w-5 h-5 shrink-0" />
            <span class="flex-1 text-sm font-medium text-ink">{t.skill.claudeWeb}</span>
            <svg class="w-4 h-4 text-sand-400 transition-transform ai-chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" /></svg>
          </button>
          <div class="ai-content hidden px-4 pb-3 font-body">
            <div class="pl-8 text-sm text-sand-600 space-y-1">
              <p><span class="font-medium text-ink">{t.skill.goTo}</span> {t.skill.claudeWebPath}</p>
              <p class="text-sand-400 text-xs">{t.skill.claudeWebHint}</p>
            </div>
          </div>
        </div>

        <!-- Claude Cowork -->
        <div class="ai-panel">
          <button class="ai-toggle w-full flex items-center gap-3 px-4 py-3 text-left hover:bg-sand-50 transition-colors cursor-pointer font-body">
            <img src="/claude.png" alt="Claude" class="w-5 h-5 shrink-0" />
            <span class="flex-1 text-sm font-medium text-ink">{t.skill.claudeCowork}</span>
            <svg class="w-4 h-4 text-sand-400 transition-transform ai-chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" /></svg>
          </button>
          <div class="ai-content hidden px-4 pb-3 font-body">
            <div class="pl-8 text-sm text-sand-600 space-y-1">
              <p><span class="font-medium text-ink">{t.skill.goTo}</span> {t.skill.claudeCoworkPath}</p>
              <p class="text-sand-400 text-xs">{t.skill.claudeCoworkHint}</p>
            </div>
          </div>
        </div>

        <!-- Grok -->
        <div class="ai-panel">
          <button class="ai-toggle w-full flex items-center gap-3 px-4 py-3 text-left hover:bg-sand-50 transition-colors cursor-pointer font-body">
            <img src="/grok.png" alt="Grok" class="w-5 h-5 shrink-0" />
            <span class="flex-1 text-sm font-medium text-ink">{t.skill.grok}</span>
            <svg class="w-4 h-4 text-sand-400 transition-transform ai-chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" /></svg>
          </button>
          <div class="ai-content hidden px-4 pb-3 font-body">
            <div class="pl-8 text-sm text-sand-600 space-y-1">
              <p><span class="font-medium text-ink">{t.skill.goTo}</span> {t.skill.grokPath}</p>
              <p class="text-sand-400 text-xs">{t.skill.grokHint}</p>
            </div>
          </div>
        </div>

      </div>
    </div>

    <!-- Details grid -->
    <div class="grid gap-5 sm:grid-cols-2 mb-10">
      <div class="bg-white border border-sand-200 rounded-lg p-5 shadow-sm">
        <h2 class="text-xs font-semibold text-sand-500 uppercase tracking-wide mb-4 font-mono">{t.skill.whatsIncluded}</h2>
        <div class="space-y-2.5 font-body">
          <div class="flex items-center gap-3">
            <span class="w-2 h-2 rounded-full bg-accent-sage"></span>
            <span class="text-sm text-ink">{t.skill.instructions}</span>
          </div>
          <div class="flex items-center gap-3">
            <span class={`w-2 h-2 rounded-full ${skill.contentType.hasScripts ? "bg-accent-sky" : "bg-sand-200"}`}></span>
            <span class={`text-sm ${skill.contentType.hasScripts ? "text-ink" : "text-sand-300"}`}>{t.skill.scripts}</span>
          </div>
          <div class="flex items-center gap-3">
            <span class={`w-2 h-2 rounded-full ${skill.contentType.hasReferences ? "bg-accent-plum" : "bg-sand-200"}`}></span>
            <span class={`text-sm ${skill.contentType.hasReferences ? "text-ink" : "text-sand-300"}`}>{t.skill.references}</span>
          </div>
          <div class="flex items-center gap-3">
            <span class={`w-2 h-2 rounded-full ${skill.contentType.hasAssets ? "bg-accent-gold" : "bg-sand-200"}`}></span>
            <span class={`text-sm ${skill.contentType.hasAssets ? "text-ink" : "text-sand-300"}`}>{t.skill.assets}</span>
          </div>
        </div>
      </div>

      <div class="bg-white border border-sand-200 rounded-lg p-5 shadow-sm">
        <h2 class="text-xs font-semibold text-sand-500 uppercase tracking-wide mb-4 font-mono">{t.skill.requirements}</h2>
        {skill.dependencies.length > 0 ? (
          <div class="space-y-2 font-body">
            {skill.dependencies.map((dep: any) => (
              <div class="flex items-center gap-2">
                <span class="text-xs px-2 py-0.5 rounded bg-sand-100 text-sand-600 font-mono">{depTypeLabels[dep.type] || dep.type}</span>
                <span class="text-sm text-ink">{dep.name}</span>
              </div>
            ))}
          </div>
        ) : (
          <div class="flex items-center gap-2 text-accent-sage font-body">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            <span class="text-sm font-medium">{t.skill.noExtras}</span>
          </div>
        )}
      </div>
    </div>

  </div>

  <script>
    // Accordion logic
    document.querySelectorAll('.ai-toggle').forEach(btn => {
      btn.addEventListener('click', () => {
        const panel = btn.closest('.ai-panel');
        if (!panel) return;
        const content = panel.querySelector('.ai-content');
        const chevron = panel.querySelector('.ai-chevron');
        const isOpen = !content?.classList.contains('hidden');

        document.querySelectorAll('.ai-panel').forEach(p => {
          p.querySelector('.ai-content')?.classList.add('hidden');
          p.querySelector('.ai-chevron')?.classList.remove('rotate-180');
        });

        if (!isOpen) {
          content?.classList.remove('hidden');
          chevron?.classList.add('rotate-180');
        }
      });
    });

    // Copy raw markdown content
    document.getElementById('copy-skill-btn')?.addEventListener('click', () => {
      const container = document.getElementById('skill-content');
      const content = container?.dataset?.rawContent || container?.textContent || '';
      navigator.clipboard.writeText(content).then(() => {
        const btn = document.getElementById('copy-skill-btn');
        if (btn) {
          const copiedText = btn.dataset.copiedText || 'Copied!';
          const orig = btn.innerHTML;
          btn.innerHTML = `<svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg> ${copiedText}`;
          setTimeout(() => { btn.innerHTML = orig; }, 2000);
        }
      });
    });
  </script>
</Base>

<style is:global>
  .skill-md h1 { font-size: 1.35rem; font-weight: 700; margin: 1.25rem 0 0.5rem; color: #0f172a; font-family: "JetBrains Mono", monospace; }
  .skill-md h2 { font-size: 1.15rem; font-weight: 600; margin: 1.1rem 0 0.4rem; color: #0f172a; font-family: "JetBrains Mono", monospace; }
  .skill-md h3 { font-size: 1rem; font-weight: 600; margin: 1rem 0 0.35rem; color: #1e293b; font-family: "JetBrains Mono", monospace; }
  .skill-md h1:first-child, .skill-md h2:first-child, .skill-md h3:first-child { margin-top: 0; }
  .skill-md p { margin: 0.5rem 0; font-family: "Inter", sans-serif; }
  .skill-md ul, .skill-md ol { margin: 0.4rem 0; padding-left: 1.5rem; font-family: "Inter", sans-serif; }
  .skill-md li { margin: 0.2rem 0; }
  .skill-md ul { list-style: disc; }
  .skill-md ol { list-style: decimal; }
  .skill-md code { font-family: "JetBrains Mono", monospace; font-size: 0.85em; background: #f1f5f9; padding: 0.15em 0.4em; border-radius: 0.3rem; color: #334155; }
  .skill-md pre { background: #f1f5f9; border: 1px solid #e2e8f0; border-radius: 0.375rem; padding: 0.75rem 1rem; margin: 0.75rem 0; overflow-x: auto; }
  .skill-md pre code { background: none; padding: 0; font-size: 0.8rem; line-height: 1.6; color: #1e293b; }
  .skill-md a { color: #2563eb; text-decoration: underline; text-underline-offset: 2px; }
  .skill-md a:hover { color: #1d4ed8; }
  .skill-md blockquote { border-left: 3px solid #e2e8f0; padding-left: 1rem; margin: 0.75rem 0; color: #475569; font-style: italic; }
  .skill-md hr { border: none; border-top: 1px solid #e2e8f0; margin: 1rem 0; }
  .skill-md table { width: 100%; border-collapse: collapse; margin: 0.75rem 0; font-size: 0.85rem; font-family: "Inter", sans-serif; }
  .skill-md th, .skill-md td { padding: 0.4rem 0.6rem; border: 1px solid #e2e8f0; text-align: left; }
  .skill-md th { background: #f1f5f9; font-weight: 600; color: #1e293b; font-family: "JetBrains Mono", monospace; }
  .skill-md strong { font-weight: 600; color: #1e293b; }
</style>
