              {skill.description ? (
                <p class="text-sm text-sand-500 mt-0.5 line-clamp-2 leading-relaxed font-body">{skill.description}</p>
              ) : (
                <p class="text-sm text-sand-400 mt-0.5 italic font-body">{t.card.by} {skill.source.split('/')[0]}</p>
              )}
              <div class="flex items-center gap-3 mt-3 text-xs text-sand-400 font-mono">
                <span class="flex items-center gap-1">
                  <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" /></svg>
                  {formatInstalls(skill.installs)}
                </span>
                {(skill.standalone && !skill.contentType.hasScripts) && (
                  <span class="flex items-center gap-1 text-accent-sage bg-accent-sage/10 px-1.5 py-0.5 rounded">
                    <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
