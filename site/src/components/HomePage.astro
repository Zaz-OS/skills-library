---
import Base from "../layouts/Base.astro";
import { useTranslations, getLocalizedPath } from '../i18n/utils';
import type { Locale } from '../i18n/translations';

interface Props {
  lang?: Locale;
}

const lang: Locale = Astro.props.lang || 'en';
const t = useTranslations(lang);
const skillPrefix = lang === 'en' ? '' : `/${lang}`;

let skills: any[] = [];
let stats: any = { totalSkills: 0, standaloneCount: 0, withDepsCount: 0, totalRepos: 0 };

try {
  const fs = await import("node:fs");
  const path = await import("node:path");
  const dataDir = path.join(process.cwd(), "../data");
  const skillsPath = path.join(dataDir, "skills.json");
  if (fs.existsSync(skillsPath)) {
    skills = JSON.parse(fs.readFileSync(skillsPath, "utf-8"));
  }
  const statsPath = path.join(dataDir, "stats.json");
  if (fs.existsSync(statsPath)) {
    stats = JSON.parse(fs.readFileSync(statsPath, "utf-8"));
  }
} catch {}

const categoryDefs = [
  {
    id: "design",
    label: t.categories.design,
    emoji: "🎨",
    description: t.categories.designDesc,
    color: "coral",
    pattern: /design|ui[/-]|ux|layout|style|css|tailwind|figma|frontend|web.?design|visual|theme/i,
  },
  {
    id: "writing",
    label: t.categories.writing,
    emoji: "✍️",
    description: t.categories.writingDesc,
    color: "sky",
    pattern: /writ|content(?!.?type)|copy(?!right)|blog|article|document|markdown|readme|text|editor|draft|prose|grammar/i,
  },
  {
    id: "marketing",
    label: t.categories.marketing,
    emoji: "📈",
    description: t.categories.marketingDesc,
    color: "gold",
    pattern: /market|seo|social|email.?(sequence|campaign|market)|campaign|brand|growth|funnel|pricing|audience|lead|advertis|landing.?page|conversion/i,
  },
  {
    id: "media",
    label: t.categories.media,
    emoji: "🖼️",
    description: t.categories.mediaDesc,
    color: "plum",
    pattern: /image.?gen|video.?gen|photo|media|canvas|animation|gif|art(?!i)|illustra|render|dalle|flux|midjourney|stable.?diff/i,
  },
  {
    id: "data",
    label: t.categories.data,
    emoji: "📊",
    description: t.categories.dataDesc,
    color: "sage",
    pattern: /data.?analy|spreadsheet|chart|report|monitor|dashboard|metric|visualiz|csv|excel|google.?sheet|bi\b|analytics/i,
  },
  {
    id: "productivity",
    label: t.categories.productivity,
    emoji: "⚡️",
    description: t.categories.productivityDesc,
    color: "rose",
    pattern: /brainstorm|plan(?!e)|organiz|workflow|automat|schedul|template|todo|productiv|project.?manag|notion|task/i,
  },
];

const TECHNICAL_KEYWORDS =
  /\b(api|sdk|cli|npm|pip|docker|kubernetes|k8s|terraform|devops|cicd|ci\/cd|backend|database|sql|nosql|graphql|grpc|microservice|deploy|git(?:hub|lab)?|aws|azure|gcloud|serverless|webpack|vite|eslint|prettier|jest|pytest|playwright|cypress|debug|compiler|runtime|binary|middleware|oauth|jwt|endpoint|webhook|localhost|daemon|container|ssh|ssl|tls|nginx|apache|redis|postgres|mysql|mongodb|kafka|elasticsearch|cron|bash|shell|powershell|regex|refactor|linting|typescript|javascript|python|rust|golang|kotlin|swift|flutter|react|nextjs|next\.js|vue|angular|svelte|nuxt|remix|astro|node\.js|deno|bun|express|fastapi|django|flask|rails|laravel|spring|supabase|prisma|drizzle|sequelize|mongoose|tailwindcss|sass|webpack|rollup|turbopack|storybook|nx|monorepo|ci|cd|yaml|json|xml|csv|protobuf|websocket|tcp|udp|http|rest|soap|rpc|ssr|ssg|hydration|jsx|tsx|component|hook|state.?management|routing|orm|migration|schema|query|index|cache|cdn|load.?balanc|proxy|gateway|queue|pub.?sub|event.?driven|hexagonal|clean.?arch|solid|design.?pattern|unit.?test|e2e|integration.?test|mock|stub|fixture|assertion|benchmark|profil|heap|stack|thread|async|promise|callback|observable|stream|buffer|pipe|stdin|stdout|stderr|env|dotenv|config|secret|token|credential|certificate|key.?pair|encrypt|decrypt|hash|salt|bcrypt|argon|crypto|solidity|smart.?contract|blockchain|web3|ethers|hardhat|foundry|truffle|openzeppelin|erc20|erc721|nft|defi|dapp|logging|log.?level|syslog|logger|observability|tracing|jaeger|datadog|grafana|prometheus|sentry|kibana|splunk|logstash|fluentd|alerting|incident|on.?call|pager|runbook|terraform|ansible|puppet|chef|vagrant|infra|iac|helm|argo|istio|envoy|consul|vault|nomad)\b/i;

function isNonDev(s: any): boolean {
  if (!s.standalone) return false;
  if (s.contentType.hasScripts) return false;
  const text = s.name + " " + (s.description || "");
  return !TECHNICAL_KEYWORDS.test(text);
}

const categorized = categoryDefs.map(cat => {
  const matched = skills.filter(s => cat.pattern.test(s.name + ' ' + (s.description || '')));
  matched.sort((a: any, b: any) => b.installs - a.installs);
  const friendly = matched.filter(s => isNonDev(s));
  const preview = friendly.length >= 3 ? friendly.slice(0, 3) : friendly.concat(matched.filter(s => !isNonDev(s))).slice(0, 3);
  return { ...cat, skills: matched, preview, count: matched.length };
});

const popular = skills.filter((s: any) => isNonDev(s)).slice(0, 12);

const recentlyAdded = skills
  .filter((s: any) => isNonDev(s) && s.standalone && !s.contentType.hasScripts)
  .sort((a: any, b: any) => {
    const dateCompare = new Date(b.firstSeen).getTime() - new Date(a.firstSeen).getTime();
    if (dateCompare !== 0) return dateCompare;
    return a.installs - b.installs;
  })
  .slice(0, 12);
const recentlyAddedTotal = skills.filter((s: any) => isNonDev(s) && s.standalone && !s.contentType.hasScripts).length;

function formatInstalls(n: number): string {
  if (n >= 1_000_000) return `${(n / 1_000_000).toFixed(1)}M`;
  if (n >= 1_000) return `${(n / 1_000).toFixed(1)}k`;
  return String(n);
}

function humanName(name: string): string {
  return name
    .replace(/[-_]/g, ' ')
    .replace(/\b\w/g, c => c.toUpperCase())
    .replace(/\bAi\b/g, 'AI')
    .replace(/\bUi\b/g, 'UI')
    .replace(/\bUx\b/g, 'UX')
    .replace(/\bSeo\b/g, 'SEO')
    .replace(/\bApi\b/g, 'API')
    .replace(/\bCss\b/g, 'CSS')
    .replace(/\bSql\b/g, 'SQL');
}

const colorMap: Record<string, {bg: string, border: string, text: string, dot: string, hover: string}> = {
  coral:  { bg: "bg-blue-50",    border: "border-blue-200/60",    text: "text-accent-coral",  dot: "bg-accent-coral",  hover: "hover:border-blue-300" },
  sky:    { bg: "bg-sky-50",     border: "border-sky-200/60",     text: "text-accent-sky",    dot: "bg-accent-sky",    hover: "hover:border-sky-300" },
  gold:   { bg: "bg-amber-50",   border: "border-amber-200/60",   text: "text-accent-gold",   dot: "bg-accent-gold",   hover: "hover:border-amber-300" },
  plum:   { bg: "bg-violet-50",  border: "border-violet-200/60",  text: "text-accent-plum",   dot: "bg-accent-plum",   hover: "hover:border-violet-300" },
  sage:   { bg: "bg-emerald-50", border: "border-emerald-200/60", text: "text-accent-sage",   dot: "bg-accent-sage",   hover: "hover:border-emerald-300" },
  rose:   { bg: "bg-rose-50",    border: "border-rose-200/60",    text: "text-accent-rose",   dot: "bg-accent-rose",   hover: "hover:border-rose-300" },
};

const clientTranslations = {
  card: {
    copyPaste: t.card.copyPaste,
    readyToUse: t.card.readyToUse,
    needsSetup: t.card.needsSetup,
    by: t.card.by,
  },
  search: {
    back: t.search.back,
    result: t.search.result,
    results: t.search.results,
    clearAll: t.search.clearAll,
    noResults: t.search.noResults,
    noResultsSub: t.search.noResultsSub,
    showMore: t.search.showMore,
    showResults: t.search.showResults,
  },
  chip: {
    nonDev: t.chip.nonDev,
    copyPaste: t.chip.copyPaste,
    not: t.chip.not,
    installs: t.chip.installs,
    installs100k: t.chip.installs100k,
    installs10k: t.chip.installs10k,
    installs1k: t.chip.installs1k,
    installs100: t.chip.installs100,
  },
  filterLabels: t.filterLabels,
  categories: {
    design: t.categories.design,
    writing: t.categories.writing,
    marketing: t.categories.marketing,
    media: t.categories.media,
    data: t.categories.data,
    productivity: t.categories.productivity,
    copyready: t.hero.copyReady,
  },
};

const pageTitle = `${t.header.brand} — ${t.hero.titleStart} ${t.hero.titleHighlight} ${t.hero.titleEnd}`;
---

<Base title={pageTitle} lang={lang}>
  <!-- Hero -->
  <section class="relative" id="hero-section">
    <div id="hero-full" class="relative max-w-3xl mx-auto px-5 pt-16 pb-14 text-center">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-sand-100 border border-sand-200 text-xs font-mono text-sand-500 mb-6">
        <span class="w-2 h-2 rounded-full bg-accent-coral animate-pulse"></span>
        {stats.totalSkills.toLocaleString()} {t.hero.badge}
      </div>
      <h1 class="font-display text-4xl sm:text-5xl font-bold leading-[1.15] tracking-tight text-ink mb-5">
        {t.hero.titleStart}<br class="hidden sm:block" />
        <span class="text-accent-coral">{t.hero.titleHighlight}</span> {t.hero.titleEnd}
      </h1>
      <p class="text-lg text-sand-600 max-w-xl mx-auto leading-relaxed mb-10 font-body">
        {t.hero.subtitle}
      </p>

      <!-- Search -->
      <div class="max-w-xl mx-auto relative group">
        <div class="absolute inset-y-0 left-0 pl-5 flex items-center pointer-events-none">
          <svg class="w-5 h-5 text-sand-400 transition-colors group-focus-within:text-accent-coral" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
          </svg>
        </div>
        <input
          id="search-input"
          type="text"
          placeholder={t.hero.searchPlaceholder}
          class="w-full pl-14 pr-5 py-4 bg-white rounded-lg border border-sand-200 text-ink placeholder-sand-400 text-base shadow-sm focus:outline-none focus:ring-2 focus:ring-accent-coral/20 focus:border-accent-coral transition-all font-mono"
          autocomplete="off"
        />
      </div>

      <!-- Quick filters -->
      <div class="flex flex-wrap justify-center gap-2 mt-5">
        <button data-quick="copyready" class="quick-filter px-3 py-1.5 text-xs font-mono rounded-md border border-sand-200 bg-white text-sand-600 hover:border-accent-sage hover:text-accent-sage transition-all cursor-pointer">
          <span class="mr-1">📋</span>{t.hero.copyReady}
        </button>
        {categoryDefs.map(cat => (
          <button data-quick={cat.id} class={`quick-filter px-3 py-1.5 text-xs font-mono rounded-md border border-sand-200 bg-white text-sand-600 transition-all cursor-pointer ${colorMap[cat.color].hover}`}>
            <span class="mr-1">{cat.emoji}</span>{cat.label}
          </button>
        ))}
      </div>
    </div>

  </section>

  <!-- ====== ADVANCED RESULTS VIEW (hidden by default) ====== -->
  <section id="advanced-section" class="hidden">
    <div id="home-root" class="max-w-6xl mx-auto px-5 pb-16" data-i18n={JSON.stringify(clientTranslations)} data-skill-prefix={skillPrefix}>
      <!-- Toolbar -->
      <div class="sticky top-[61px] z-40 bg-sand-50/95 backdrop-blur-sm -mx-5 px-5 pt-4 pb-4 border-b border-sand-200 mb-5">
        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
          <div class="flex items-center gap-3 min-w-0">
            <button id="back-browse" class="shrink-0 flex items-center gap-1.5 text-sm text-sand-500 hover:text-accent-coral transition-colors cursor-pointer group font-mono">
              <svg class="w-4 h-4 transition-transform group-hover:-translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" /></svg>
              {t.search.back}
            </button>
            <span class="w-px h-4 bg-sand-200"></span>
            <h2 id="adv-title" class="font-display text-lg font-semibold text-ink truncate"></h2>
            <span id="adv-count" class="shrink-0 text-sm text-sand-400 tabular-nums font-mono"></span>
          </div>
          <div class="flex items-center gap-2 w-full sm:w-auto">
            <div class="relative group flex-1 sm:w-64">
              <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                <svg class="w-4 h-4 text-sand-400 transition-colors group-focus-within:text-accent-coral" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
                </svg>
              </div>
              <input
                id="search-input-compact"
                type="text"
                placeholder={t.search.searchPlaceholder}
                class="w-full pl-9 pr-3 py-1.5 bg-white rounded-md border border-sand-200 text-ink placeholder-sand-400 text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-accent-coral/20 focus:border-accent-coral transition-all font-mono"
                autocomplete="off"
              />
            </div>
            <button id="filter-toggle-mobile" class="lg:hidden shrink-0 flex items-center gap-1.5 px-3 py-1.5 text-sm rounded-md border border-sand-200 bg-white text-sand-600 hover:border-sand-300 transition-all cursor-pointer font-mono" type="button">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 6h9.75M10.5 6a1.5 1.5 0 11-3 0m3 0a1.5 1.5 0 10-3 0M3.75 6H7.5m3 12h9.75m-9.75 0a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m-3.75 0H7.5m9-6h3.75m-3.75 0a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m-9.75 0h9.75" /></svg>
              {t.search.filters}
              <span id="filter-count-badge" class="hidden min-w-[18px] h-[18px] text-[10px] font-bold bg-accent-coral text-white rounded-full px-1 leading-[18px] text-center">0</span>
            </button>
            <select id="sort-select" class="shrink-0 text-sm bg-white border border-sand-200 rounded-md px-3 py-1.5 text-ink cursor-pointer focus:outline-none focus:ring-2 focus:ring-accent-coral/20 focus:border-accent-coral appearance-none bg-[url('data:image/svg+xml;charset=utf-8,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20fill%3D%22none%22%20viewBox%3D%220%200%2024%2024%22%20stroke%3D%22%2394a3b8%22%20stroke-width%3D%222%22%3E%3Cpath%20stroke-linecap%3D%22round%22%20stroke-linejoin%3D%22round%22%20d%3D%22M19.5%208.25l-7.5%207.5-7.5-7.5%22%20%2F%3E%3C%2Fsvg%3E')] bg-[length:16px] bg-[right_8px_center] bg-no-repeat pr-8 font-mono hidden sm:block">
              <option value="installs">{t.search.sortPopular}</option>
              <option value="name">{t.search.sortName}</option>
              <option value="stars">{t.search.sortStars}</option>
            </select>
          </div>
        </div>
      </div>

      <!-- Active filter chips -->
      <div id="active-chips" class="flex flex-wrap items-center gap-1.5 mb-4 empty:hidden"></div>

      <!-- Two-column: sidebar + grid -->
      <div class="flex gap-8">
        <!-- Filter sidebar (desktop) -->
        <aside id="sidebar-container" class="hidden lg:block w-[260px] shrink-0">
          <div class="sticky top-[65px] max-h-[calc(100vh-80px)] overflow-y-auto pr-2 -mr-2">
            <div id="filter-content" class="space-y-6 pb-8">

              <!-- For you -->
              <div>
                <h3 class="text-xs font-semibold text-sand-400 uppercase tracking-wider mb-3 font-mono">{t.filterLabels.forYou}</h3>
                <div class="space-y-1">
                  <label class="flex items-center gap-2.5 px-3 py-2 rounded-md hover:bg-sand-100/50 cursor-pointer transition-colors">
                    <input type="checkbox" data-toggle="nonDev" class="w-4 h-4 rounded border-sand-300 text-accent-sage focus:ring-accent-sage/30 cursor-pointer" />
                    <span class="text-sm text-sand-700 font-mono">{t.filterLabels.nonDev}</span>
                  </label>
                  <label class="flex items-center gap-2.5 px-3 py-2 rounded-md hover:bg-sand-100/50 cursor-pointer transition-colors">
                    <input type="checkbox" data-toggle="copyReady" class="w-4 h-4 rounded border-sand-300 text-accent-sage focus:ring-accent-sage/30 cursor-pointer" />
                    <span class="text-sm text-sand-700 font-mono">{t.filterLabels.copyReady}</span>
                  </label>
                </div>
              </div>

              <!-- What's included -->
              <div>
                <h3 class="text-xs font-semibold text-sand-400 uppercase tracking-wider mb-3 font-mono">{t.filterLabels.whatsIncluded}</h3>
                <div class="space-y-1">
                  <button data-tri="scripts" data-state="off" class="tri-pill" type="button">
                    <span class="tri-icon shrink-0"></span>
                    <span class="tri-label">{t.filterLabels.scripts}</span>
                  </button>
                  <button data-tri="references" data-state="off" class="tri-pill" type="button">
                    <span class="tri-icon shrink-0"></span>
                    <span class="tri-label">{t.filterLabels.references}</span>
                  </button>
                  <button data-tri="assets" data-state="off" class="tri-pill" type="button">
                    <span class="tri-icon shrink-0"></span>
                    <span class="tri-label">{t.filterLabels.assets}</span>
                  </button>
                </div>
              </div>

              <!-- Setup needs -->
              <div>
                <h3 class="text-xs font-semibold text-sand-400 uppercase tracking-wider mb-3 font-mono">{t.filterLabels.setupNeeds}</h3>
                <div class="space-y-1">
                  <button data-tri="standalone" data-state="off" class="tri-pill" type="button">
                    <span class="tri-icon shrink-0"></span>
                    <span class="tri-label">{t.filterLabels.noSetup}</span>
                  </button>
                  <button data-tri="needsNpm" data-state="off" class="tri-pill" type="button">
                    <span class="tri-icon shrink-0"></span>
                    <span class="tri-label">{t.filterLabels.npm}</span>
                  </button>
                  <button data-tri="needsPip" data-state="off" class="tri-pill" type="button">
                    <span class="tri-icon shrink-0"></span>
                    <span class="tri-label">{t.filterLabels.pip}</span>
                  </button>
                  <button data-tri="needsBrew" data-state="off" class="tri-pill" type="button">
                    <span class="tri-icon shrink-0"></span>
                    <span class="tri-label">{t.filterLabels.brew}</span>
                  </button>
                  <button data-tri="needsSystem" data-state="off" class="tri-pill" type="button">
                    <span class="tri-icon shrink-0"></span>
                    <span class="tri-label">{t.filterLabels.system}</span>
                  </button>
                  <button data-tri="needsService" data-state="off" class="tri-pill" type="button">
                    <span class="tri-icon shrink-0"></span>
                    <span class="tri-label">{t.filterLabels.service}</span>
                  </button>
                </div>
              </div>

              <!-- Category -->
              <div>
                <h3 class="text-xs font-semibold text-sand-400 uppercase tracking-wider mb-3 font-mono">{t.filterLabels.category}</h3>
                <div class="flex flex-wrap gap-1.5">
                  <button data-cat="design" class="cat-pill" type="button">🎨 {t.categories.design}</button>
                  <button data-cat="writing" class="cat-pill" type="button">✍️ {t.categories.writing}</button>
                  <button data-cat="marketing" class="cat-pill" type="button">📈 {t.categories.marketing}</button>
                  <button data-cat="media" class="cat-pill" type="button">🖼️ {t.categories.media}</button>
                  <button data-cat="data" class="cat-pill" type="button">📊 {t.categories.data}</button>
                  <button data-cat="productivity" class="cat-pill" type="button">⚡️ {t.categories.productivity}</button>
                </div>
              </div>

              <!-- Popularity -->
              <div>
                <h3 class="text-xs font-semibold text-sand-400 uppercase tracking-wider mb-3 font-mono">{t.filterLabels.popularity}</h3>
                <div class="space-y-1">
                  <label class="flex items-center gap-2.5 px-3 py-1.5 rounded-md hover:bg-sand-100/50 cursor-pointer transition-colors">
                    <input type="radio" name="popularity" value="0" checked class="w-4 h-4 border-sand-300 text-accent-coral focus:ring-accent-coral/30 cursor-pointer" />
                    <span class="text-sm text-sand-700 font-mono">{t.filterLabels.any}</span>
                  </label>
                  <label class="flex items-center gap-2.5 px-3 py-1.5 rounded-md hover:bg-sand-100/50 cursor-pointer transition-colors">
                    <input type="radio" name="popularity" value="100" class="w-4 h-4 border-sand-300 text-accent-coral focus:ring-accent-coral/30 cursor-pointer" />
                    <span class="text-sm text-sand-700 font-mono">{t.filterLabels.installs100}</span>
                  </label>
                  <label class="flex items-center gap-2.5 px-3 py-1.5 rounded-md hover:bg-sand-100/50 cursor-pointer transition-colors">
                    <input type="radio" name="popularity" value="1000" class="w-4 h-4 border-sand-300 text-accent-coral focus:ring-accent-coral/30 cursor-pointer" />
                    <span class="text-sm text-sand-700 font-mono">{t.filterLabels.installs1k}</span>
                  </label>
                  <label class="flex items-center gap-2.5 px-3 py-1.5 rounded-md hover:bg-sand-100/50 cursor-pointer transition-colors">
                    <input type="radio" name="popularity" value="10000" class="w-4 h-4 border-sand-300 text-accent-coral focus:ring-accent-coral/30 cursor-pointer" />
                    <span class="text-sm text-sand-700 font-mono">{t.filterLabels.installs10k}</span>
                  </label>
                  <label class="flex items-center gap-2.5 px-3 py-1.5 rounded-md hover:bg-sand-100/50 cursor-pointer transition-colors">
                    <input type="radio" name="popularity" value="100000" class="w-4 h-4 border-sand-300 text-accent-coral focus:ring-accent-coral/30 cursor-pointer" />
                    <span class="text-sm text-sand-700 font-mono">{t.filterLabels.installs100k}</span>
                  </label>
                </div>
              </div>

            </div>
