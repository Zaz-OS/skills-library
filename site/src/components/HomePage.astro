        </div>
        <span class="text-sm text-sand-400 hidden sm:block font-mono">{recentlyAddedTotal.toLocaleString()} {t.categories.skillsCount}</span>
      </div>
      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
        {recentlyAdded.map((skill: any) => (
          <a href={getLocalizedPath(`/skill/${skill.id}`, lang)}
             class="group block bg-white border border-sand-200 rounded-lg p-4 hover:border-accent-sage/40 hover:shadow-sm transition-all">
            <div class="flex items-center gap-1.5 mb-2">
              <span class="flex items-center gap-1 text-xs text-accent-sage font-mono bg-accent-sage/10 px-1.5 py-0.5 rounded">
                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                {t.recent.copyPaste}
              </span>
            </div>
            <h3 class="font-medium text-ink text-sm truncate group-hover:text-accent-sage transition-colors font-display">
              {humanName(skill.name)}
            </h3>
            <p class="text-xs text-sand-400 mt-2 truncate font-mono">{formatInstalls(skill.installs)} {t.recent.installs}</p>
          </a>
        ))}
      </div>
    </section>

  </div>

  <script>
    import Fuse from "fuse.js";

    interface SkillItem {
      id: string;
      name: string;
      description: string;
      source: string;
      skillId: string;
      installs: number;
      stars: number;
      standalone: boolean;
      deps: string;
      depTypes: string;
      content: string;
      nonDev: boolean;
    }

    type TriState = 'off' | 'include' | 'exclude';

    interface FilterStore {
      nonDev: boolean;
      copyReady: boolean;
      scripts: TriState;
      references: TriState;
      assets: TriState;
      standalone: TriState;
      needsNpm: TriState;
      needsPip: TriState;
      needsBrew: TriState;
      needsSystem: TriState;
      needsService: TriState;
      categories: Set<string>;
      minInstalls: number;
      sortBy: string;
    }

    const homeRoot = document.getElementById('home-root');
    const clientT = JSON.parse(homeRoot?.dataset.i18n || '{}');
    const skillPrefix = homeRoot?.dataset.skillPrefix || '';

    let fuse: Fuse<SkillItem>;
    let allItems: SkillItem[] = [];
    let baseResults: SkillItem[] = [];
    let filteredResults: SkillItem[] = [];
    let displayCount = 24;
    let currentTitle = '';
    let filters: FilterStore = getDefaultFilters();

    function getDefaultFilters(): FilterStore {
      return {
        nonDev: false,
        copyReady: false,
        scripts: 'off',
        references: 'off',
        assets: 'off',
        standalone: 'off',
        needsNpm: 'off',
        needsPip: 'off',
        needsBrew: 'off',
        needsSystem: 'off',
        needsService: 'off',
        categories: new Set(),
        minInstalls: 0,
        sortBy: 'installs',
      };
    }

    const categoryPatterns: Record<string, RegExp> = {
      design: /design|ui[/-]|ux|layout|style|css|tailwind|figma|frontend|web.?design|visual|theme/i,
      writing: /writ|content(?!.?type)|copy(?!right)|blog|article|document|markdown|readme|text|editor|draft|prose|grammar/i,
      marketing: /market|seo|social|email.?(sequence|campaign|market)|campaign|brand|growth|funnel|pricing|audience|lead|advertis|landing.?page|conversion/i,
      media: /image.?gen|video.?gen|photo|media|canvas|animation|gif|art(?!i)|illustra|render|dalle|flux|midjourney|stable.?diff/i,
      data: /data.?analy|spreadsheet|chart|report|monitor|dashboard|metric|visualiz|csv|excel|google.?sheet|bi\b|analytics/i,
      productivity: /brainstorm|plan(?!e)|organiz|workflow|automat|schedul|template|todo|productiv|project.?manag|notion|task/i,
    };

    const categoryLabels: Record<string, string> = clientT.categories || {
      design: "Design & UI",
      writing: "Writing & Docs",
      marketing: "Marketing & SEO",
      media: "Images & Video",
      data: "Data & Analytics",
      productivity: "Productivity",
      copyready: "Copy & paste ready",
    };

    const triFilterLabels: Record<string, string> = {
      scripts: clientT.filterLabels?.scripts || 'Scripts',
      references: clientT.filterLabels?.references || 'References',
      assets: clientT.filterLabels?.assets || 'Assets',
      standalone: clientT.filterLabels?.noSetup || 'No setup',
      needsNpm: clientT.filterLabels?.npm || 'npm',
      needsPip: clientT.filterLabels?.pip || 'Python',
      needsBrew: clientT.filterLabels?.brew || 'Homebrew',
      needsSystem: clientT.filterLabels?.system || 'System tools',
      needsService: clientT.filterLabels?.service || 'Services',
    };

    const TRI_ICONS = {
      off: `<svg class="w-4 h-4 text-[#c9bfae]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="9" /></svg>`,
      include: `<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`,
      exclude: `<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 9.75l4.5 4.5m0-4.5l-4.5 4.5M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`,
    };

    function humanName(name: string): string {
      return name
        .replace(/[-_]/g, ' ')
        .replace(/\b\w/g, (c: string) => c.toUpperCase())
        .replace(/\bAi\b/g, 'AI').replace(/\bUi\b/g, 'UI').replace(/\bUx\b/g, 'UX')
        .replace(/\bSeo\b/g, 'SEO').replace(/\bApi\b/g, 'API').replace(/\bCss\b/g, 'CSS').replace(/\bSql\b/g, 'SQL');
    }

    function formatInstalls(n: number): string {
      if (n >= 1_000_000) return `${(n / 1_000_000).toFixed(1)}M`;
      if (n >= 1_000) return `${(n / 1_000).toFixed(1)}k`;
      return String(n);
    }

    function escapeHtml(str: string): string {
      return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    function isCopyReady(s: SkillItem): boolean {
      return s.standalone && !s.content.includes('scripts');
    }

    function renderCard(s: SkillItem): string {
      const copyReady = isCopyReady(s);
      const cardT = clientT.card || {};
      const badge = copyReady
        ? `<span class="flex items-center gap-1 text-xs text-[#059669] font-mono bg-[#f0fdf4] px-1.5 py-0.5 rounded">
             <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
             ${escapeHtml(cardT.copyPaste || 'Copy & paste')}
           </span>`
        : s.standalone
          ? `<span class="text-xs text-[#0284c7] font-mono bg-[#f0f9ff] px-1.5 py-0.5 rounded">${escapeHtml(cardT.readyToUse || 'Ready to use')}</span>`
          : `<span class="text-xs text-[#d97706] font-mono bg-[#fffbeb] px-1.5 py-0.5 rounded">${escapeHtml(cardT.needsSetup || 'Needs setup')}</span>`;

      const desc = s.description
        ? `<p class="text-sm text-[#475569] mt-1 line-clamp-2 leading-relaxed font-body">${escapeHtml(s.description)}</p>`
        : `<p class="text-sm text-[#94a3b8] mt-1 italic font-body">${escapeHtml(cardT.by || 'by')} ${escapeHtml(s.source.split('/')[0])}</p>`;

      return `
        <a href="${skillPrefix}/skill/${s.id}" class="group flex items-start gap-3.5 bg-white border border-[#e2e8f0] rounded-lg p-4 hover:border-[#cbd5e1] hover:shadow-sm transition-all">
          <div class="min-w-0 flex-1">
            <h3 class="font-medium text-[#0f172a] truncate group-hover:text-[#2563eb] transition-colors font-display">${escapeHtml(humanName(s.name))}</h3>
            ${desc}
            <div class="flex items-center gap-3 mt-3 text-xs text-[#64748b] font-mono">
              <span class="flex items-center gap-1">
                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" /></svg>
                ${formatInstalls(s.installs)}
              </span>
              ${s.stars > 0 ? `<span class="flex items-center gap-1"><svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" /></svg>${formatInstalls(s.stars)}</span>` : ''}
              ${badge}
            </div>
          </div>
        </a>`;
    }

    function matchesFilters(s: SkillItem): boolean {
      const f = filters;

      if (f.nonDev && !s.nonDev) return false;
      if (f.copyReady && !isCopyReady(s)) return false;

      if (f.scripts === 'include' && !s.content.includes('scripts')) return false;
      if (f.scripts === 'exclude' && s.content.includes('scripts')) return false;
      if (f.references === 'include' && !s.content.includes('references')) return false;
      if (f.references === 'exclude' && s.content.includes('references')) return false;
      if (f.assets === 'include' && !s.content.includes('assets')) return false;
      if (f.assets === 'exclude' && s.content.includes('assets')) return false;

      if (f.standalone === 'include' && !s.standalone) return false;
      if (f.standalone === 'exclude' && s.standalone) return false;
      if (f.needsNpm === 'include' && !s.depTypes.includes('npm')) return false;
      if (f.needsNpm === 'exclude' && s.depTypes.includes('npm')) return false;
      if (f.needsPip === 'include' && !s.depTypes.includes('pip')) return false;
      if (f.needsPip === 'exclude' && s.depTypes.includes('pip')) return false;
      if (f.needsBrew === 'include' && !s.depTypes.includes('brew')) return false;
      if (f.needsBrew === 'exclude' && s.depTypes.includes('brew')) return false;
      if (f.needsSystem === 'include' && !s.depTypes.includes('system')) return false;
      if (f.needsSystem === 'exclude' && s.depTypes.includes('system')) return false;
      if (f.needsService === 'include' && !s.depTypes.includes('service')) return false;
      if (f.needsService === 'exclude' && s.depTypes.includes('service')) return false;

      if (f.categories.size > 0) {
        const text = s.name + ' ' + s.description;
        const matchesCat = [...f.categories].some(cat => categoryPatterns[cat]?.test(text));
        if (!matchesCat) return false;
      }

      if (s.installs < f.minInstalls) return false;

      return true;
    }

    function countActiveFilters(): number {
      let count = 0;
      if (filters.nonDev) count++;
      if (filters.copyReady) count++;
      const triKeys: (keyof FilterStore)[] = ['scripts', 'references', 'assets', 'standalone', 'needsNpm', 'needsPip', 'needsBrew', 'needsSystem', 'needsService'];
      for (const key of triKeys) {
        if (filters[key] !== 'off') count++;
      }
      count += filters.categories.size;
      if (filters.minInstalls > 0) count++;
      return count;
    }

    const catEmojis: Record<string, string> = {
      design: '🎨', writing: '✍️', marketing: '📈',
      media: '🖼️', data: '📊', productivity: '⚡️',
    };

    function renderChips() {
      const container = document.getElementById('active-chips')!;
      const chips: string[] = [];
      const chipT = clientT.chip || {};
      const searchT = clientT.search || {};

      if (filters.nonDev) chips.push(makeChip(chipT.nonDev || 'Non-developer', 'toggle', 'nonDev', 'sage'));
      if (filters.copyReady) chips.push(makeChip(chipT.copyPaste || 'Copy & paste', 'toggle', 'copyReady', 'sage'));

      for (const [key, label] of Object.entries(triFilterLabels)) {
        const val = (filters as any)[key];
        if (val === 'include') chips.push(makeChip(label, 'tri', key, 'sage'));
        else if (val === 'exclude') chips.push(makeChip(`${chipT.not || 'NOT:'} ${label}`, 'tri', key, 'rose'));
      }

      for (const cat of filters.categories) {
        chips.push(makeChip(`${catEmojis[cat] || ''} ${categoryLabels[cat] || cat}`, 'cat', cat, 'coral'));
      }

      if (filters.minInstalls > 0) {
        const label = filters.minInstalls >= 100000 ? (chipT.installs100k || '100k+')
          : filters.minInstalls >= 10000 ? (chipT.installs10k || '10k+')
          : filters.minInstalls >= 1000 ? (chipT.installs1k || '1k+')
          : (chipT.installs100 || '100+');
        chips.push(makeChip(`${label} ${chipT.installs || 'installs'}`, 'pop', '0', 'gold'));
      }

      if (chips.length > 0) {
        chips.push(`<button id="clear-all-btn" class="text-xs text-[#a99e8e] hover:text-[#e8613c] transition-colors ml-1 cursor-pointer" type="button">${escapeHtml(searchT.clearAll || 'Clear all')}</button>`);
      }

      container.innerHTML = chips.join('');

      document.getElementById('clear-all-btn')?.addEventListener('click', () => {
        resetFilters();
        syncFilterUI();
        applyFiltersAndSort();
      });

      container.querySelectorAll('[data-remove-chip]').forEach(btn => {
        btn.addEventListener('click', () => {
          const el = btn as HTMLElement;
          const type = el.dataset.chipType!;
          const key = el.dataset.removeChip!;
          if (type === 'toggle') (filters as any)[key] = false;
          else if (type === 'tri') (filters as any)[key] = 'off';
          else if (type === 'cat') filters.categories.delete(key);
          else if (type === 'pop') filters.minInstalls = 0;
          syncFilterUI();
          applyFiltersAndSort();
        });
      });

      const badge = document.getElementById('filter-count-badge');
      const count = countActiveFilters();
      if (badge) {
        badge.textContent = String(count);
        badge.classList.toggle('hidden', count === 0);
      }
    }

    function makeChip(label: string, type: string, key: string, color: string): string {
      const colors: Record<string, { bg: string; text: string; border: string }> = {
        sage: { bg: '#f0fdf4', text: '#059669', border: '#bbf7d0' },
        rose: { bg: '#fff1f2', text: '#e11d48', border: '#fecdd3' },
        coral: { bg: '#eff6ff', text: '#2563eb', border: '#bfdbfe' },
        gold: { bg: '#fffbeb', text: '#d97706', border: '#fde68a' },
      };
      const c = colors[color] || colors.sage;
      return `<span class="inline-flex items-center gap-1 px-2.5 py-1 text-xs rounded-md font-mono" style="background:${c.bg};color:${c.text};border:1px solid ${c.border}">
        ${escapeHtml(label)}
        <button data-remove-chip="${key}" data-chip-type="${type}" class="hover:opacity-70 cursor-pointer ml-0.5" type="button">&times;</button>
      </span>`;
    }

    function updateTriPill(btn: HTMLElement) {
      const state = (btn.dataset.state || 'off') as TriState;
      const icon = btn.querySelector('.tri-icon');
      const label = btn.querySelector('.tri-label');
      if (icon) icon.innerHTML = TRI_ICONS[state];
      if (label) {
        if (state === 'exclude') label.classList.add('line-through');
        else label.classList.remove('line-through');
      }
    }

    function cycleTriState(current: TriState): TriState {
      if (current === 'off') return 'include';
      if (current === 'include') return 'exclude';
      return 'off';
    }

    function resetFilters() {
      filters = getDefaultFilters();
    }

    function syncFilterUI() {
      document.querySelectorAll<HTMLInputElement>('[data-toggle]').forEach(cb => {
        cb.checked = !!(filters as any)[cb.dataset.toggle!];
      });
      document.querySelectorAll<HTMLElement>('[data-tri]').forEach(btn => {
        btn.dataset.state = (filters as any)[btn.dataset.tri!] || 'off';
        updateTriPill(btn);
      });
      document.querySelectorAll<HTMLElement>('[data-cat]').forEach(btn => {
        if (filters.categories.has(btn.dataset.cat!)) btn.dataset.active = 'true';
        else delete btn.dataset.active;
      });
      document.querySelectorAll<HTMLInputElement>('input[name="popularity"]').forEach(r => {
        r.checked = Number(r.value) === filters.minInstalls;
      });
      (document.getElementById('sort-select') as HTMLSelectElement).value = filters.sortBy;
    }

    function applyFiltersAndSort() {
      let items = baseResults.filter(matchesFilters);

      if (filters.sortBy === 'installs') items.sort((a, b) => b.installs - a.installs);
      else if (filters.sortBy === 'name') items.sort((a, b) => a.name.localeCompare(b.name));
      else if (filters.sortBy === 'stars') items.sort((a, b) => b.stars - a.stars);

      filteredResults = items;
      displayCount = 24;
      renderGrid();
      renderChips();

      const drawerCount = document.getElementById('drawer-result-count');
      if (drawerCount) drawerCount.textContent = String(filteredResults.length);
    }

    function renderGrid() {
      const grid = document.getElementById('adv-grid')!;
      const empty = document.getElementById('adv-empty')!;
      const more = document.getElementById('adv-more')!;
      const count = document.getElementById('adv-count')!;

      const searchT = clientT.search || {};
      const resultWord = filteredResults.length !== 1 ? (searchT.results || 'results') : (searchT.result || 'result');
      count.textContent = `${filteredResults.length} ${resultWord}`;

      if (filteredResults.length === 0) {
        grid.innerHTML = '';
        empty.classList.remove('hidden');
        more.classList.add('hidden');
        return;
      }

      empty.classList.add('hidden');
      grid.innerHTML = filteredResults.slice(0, displayCount).map(renderCard).join('');
      more.classList.toggle('hidden', filteredResults.length <= displayCount);
    }

    function openDrawer() {
      const filterContent = document.getElementById('filter-content')!;
      const drawerContent = document.getElementById('drawer-content')!;
      const overlay = document.getElementById('filter-overlay')!;
      const drawer = document.getElementById('filter-drawer')!;

      drawerContent.appendChild(filterContent);
      overlay.classList.remove('hidden');
      drawer.classList.remove('hidden');
      requestAnimationFrame(() => drawer.classList.remove('translate-y-full'));
      document.body.style.overflow = 'hidden';

      const dc = document.getElementById('drawer-result-count');
      if (dc) dc.textContent = String(filteredResults.length);
    }

    function closeDrawer() {
      const filterContent = document.getElementById('filter-content')!;
      const sidebarSticky = document.querySelector('#sidebar-container > div')!;
      const overlay = document.getElementById('filter-overlay')!;
      const drawer = document.getElementById('filter-drawer')!;

      drawer.classList.add('translate-y-full');
      setTimeout(() => {
        overlay.classList.add('hidden');
        drawer.classList.add('hidden');
        sidebarSticky.appendChild(filterContent);
      }, 300);
      document.body.style.overflow = '';
    }

    function enterAdvancedMode(results: SkillItem[], title: string) {
      baseResults = results;
      currentTitle = title;
      document.getElementById('adv-title')!.textContent = title;

      resetFilters();
      syncFilterUI();

      document.getElementById('hero-full')!.classList.add('hidden');
      document.getElementById('advanced-section')!.classList.remove('hidden');
      document.getElementById('discovery')!.classList.add('hidden');

      const mainInput = document.getElementById('search-input') as HTMLInputElement;
      const compactInput = document.getElementById('search-input-compact') as HTMLInputElement;
      compactInput.value = mainInput.value;

      applyFiltersAndSort();
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function exitAdvancedMode() {
      document.getElementById('hero-full')!.classList.remove('hidden');
      document.getElementById('advanced-section')!.classList.add('hidden');
      document.getElementById('discovery')!.classList.remove('hidden');

      (document.getElementById('search-input') as HTMLInputElement).value = '';
      (document.getElementById('search-input-compact') as HTMLInputElement).value = '';

      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    async function init() {
      try {
        const res = await fetch("/api/search-index.json");
        if (!res.ok) return;
        allItems = await res.json();

        fuse = new Fuse(allItems, {
          keys: [
            { name: "name", weight: 2 },
            { name: "description", weight: 1.5 },
            { name: "deps", weight: 0.5 },
            { name: "source", weight: 0.3 },
          ],
          threshold: 0.35,
          includeScore: true,
        });

        document.querySelectorAll<HTMLElement>('[data-tri]').forEach(updateTriPill);

        const searchInput = document.getElementById('search-input') as HTMLInputElement;
        const compactInput = document.getElementById('search-input-compact') as HTMLInputElement;

        searchInput.addEventListener('keydown', (e) => {
          if (e.key === 'Enter') {
            const q = searchInput.value.trim();
            if (!q) return;
            enterAdvancedMode(fuse.search(q).map(r => r.item), `"${q}"`);
          }
        });

        compactInput.addEventListener('input', () => {
          const q = compactInput.value.trim();
          if (!q) {
            exitAdvancedMode();
            return;
          }
          baseResults = fuse.search(q).map(r => r.item);
          document.getElementById('adv-title')!.textContent = `"${q}"`;
          applyFiltersAndSort();
        });

        compactInput.addEventListener('keydown', (e) => {
          if (e.key === 'Enter') {
            e.preventDefault();
          }
        });

        document.querySelectorAll('.quick-filter').forEach(btn => {
          btn.addEventListener('click', () => {
            const filterId = (btn as HTMLElement).dataset.quick!;
            let results: SkillItem[];
            let title: string;
            if (filterId === 'copyready') {
              results = allItems.filter(s => isCopyReady(s));
              results.sort((a, b) => b.installs - a.installs);
              title = categoryLabels['copyready'] || 'Copy & paste ready';
            } else {
              const pattern = categoryPatterns[filterId];
              results = allItems.filter(s => pattern.test(s.name + ' ' + s.description));
              results.sort((a, b) => b.installs - a.installs);
              title = categoryLabels[filterId] || filterId;
            }
            enterAdvancedMode(results, title);
          });
        });

        document.querySelectorAll('[data-category-card]').forEach(card => {
          card.addEventListener('click', (e) => {
            e.preventDefault();
            const catId = (card as HTMLElement).dataset.categoryCard!;
            const pattern = categoryPatterns[catId];
            const results = allItems.filter(s => pattern.test(s.name + ' ' + s.description));
            results.sort((a, b) => b.installs - a.installs);
            enterAdvancedMode(results, categoryLabels[catId] || catId);
          });
        });

        document.getElementById('back-browse')?.addEventListener('click', exitAdvancedMode);

        document.getElementById('sort-select')?.addEventListener('change', (e) => {
          filters.sortBy = (e.target as HTMLSelectElement).value;
          applyFiltersAndSort();
        });

        document.querySelectorAll<HTMLInputElement>('[data-toggle]').forEach(cb => {
          cb.addEventListener('change', () => {
            (filters as any)[cb.dataset.toggle!] = cb.checked;
            applyFiltersAndSort();
          });
        });

        document.querySelectorAll<HTMLElement>('[data-tri]').forEach(btn => {
          btn.addEventListener('click', () => {
            const key = btn.dataset.tri!;
            const current = (filters as any)[key] as TriState;
            const next = cycleTriState(current);
            (filters as any)[key] = next;
            btn.dataset.state = next;
            updateTriPill(btn);
            applyFiltersAndSort();
          });
        });

        document.querySelectorAll<HTMLElement>('[data-cat]').forEach(btn => {
          btn.addEventListener('click', () => {
            const cat = btn.dataset.cat!;
            if (filters.categories.has(cat)) {
              filters.categories.delete(cat);
              delete btn.dataset.active;
            } else {
              filters.categories.add(cat);
              btn.dataset.active = 'true';
            }
            applyFiltersAndSort();
          });
        });

        document.querySelectorAll<HTMLInputElement>('input[name="popularity"]').forEach(r => {
          r.addEventListener('change', () => {
            filters.minInstalls = Number(r.value);
            applyFiltersAndSort();
          });
        });

        document.getElementById('filter-toggle-mobile')?.addEventListener('click', openDrawer);
        document.getElementById('close-drawer')?.addEventListener('click', closeDrawer);
        document.getElementById('filter-overlay')?.addEventListener('click', closeDrawer);
        document.getElementById('drawer-show-results')?.addEventListener('click', closeDrawer);

        document.getElementById('adv-more')?.addEventListener('click', () => {
          displayCount += 24;
          const grid = document.getElementById('adv-grid')!;
          const more = document.getElementById('adv-more')!;
          grid.insertAdjacentHTML('beforeend', filteredResults.slice(displayCount - 24, displayCount).map(renderCard).join(''));
          more.classList.toggle('hidden', filteredResults.length <= displayCount);
        });

      } catch {
        // Search index not available
      }
    }

    init();
  </script>
</Base>

<style>
  @keyframes fade-in-up {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
  }

  #discovery > section {
    animation: fade-in-up 0.5s ease-out both;
  }

  #discovery > section:nth-child(2) { animation-delay: 0.05s; }
  #discovery > section:nth-child(3) { animation-delay: 0.1s; }
  #discovery > section:nth-child(4) { animation-delay: 0.15s; }

  .tri-pill {
    width: 100%;
    display: flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.5rem 0.75rem;
    font-size: 0.875rem;
    border-radius: 0.375rem;
    border: 1px solid #e2e8f0;
    background: white;
    color: #475569;
    cursor: pointer;
    transition: all 150ms;
    text-align: left;
    font-family: "Inter", sans-serif;
  }

  .tri-pill:hover { border-color: #cbd5e1; }

  .tri-pill[data-state="include"] {
    border-color: #bbf7d0;
    background: #f0fdf4;
    color: #059669;
  }

  .tri-pill[data-state="exclude"] {
    border-color: #fecdd3;
    background: #fff1f2;
    color: #e11d48;
  }

  .cat-pill {
    padding: 0.375rem 0.625rem;
    font-size: 0.75rem;
    border-radius: 0.375rem;
    border: 1px solid #e2e8f0;
    background: white;
    color: #475569;
    cursor: pointer;
    transition: all 150ms;
    font-family: "Inter", sans-serif;
  }

  .cat-pill:hover { border-color: #cbd5e1; }

  .cat-pill[data-active="true"] {
    border-color: #bfdbfe;
    background: #eff6ff;
    color: #2563eb;
  }
</style>
