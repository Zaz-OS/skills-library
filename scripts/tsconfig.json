{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "rootDir": "..",
    "sourceMap": true,
    "noEmit": false
  },
  "include": ["src/**/*.ts", "../types/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
